<%
  currentPage = 'habilidades';
%>
<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1 class="page-title">Mis <span class="text-gradient">Habilidades</span></h1>
    <p class="page-subtitle">Tecnologías y herramientas que domino</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if (Object.keys(grupos).length > 0) { %>
      <% Object.keys(grupos).forEach(cat => { %>
      <div class="skills-group animate-on-scroll">
        <h3 class="skills-group-title"><i class="fas fa-layer-group"></i> <%= cat %></h3>
        <div class="skills-grid">
          <% grupos[cat].forEach(h => { %>
          <div class="skill-card">
            <div class="skill-header">
              <div class="skill-icon"><i class="<%= h.icono %>"></i></div>
              <div class="skill-info">
                <span class="skill-name"><%= h.nombre %></span>
                <span class="skill-pct"><%= h.porcentaje %>%</span>
              </div>
            </div>
            <div class="skill-bar">
              <div class="skill-fill" data-width="<%= h.porcentaje %>"></div>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% }) %>
    <% } else { %>
      <p class="no-data">Habilidades próximamente...</p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
