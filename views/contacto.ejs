<%
  currentPage = 'contacto';
%>
<%- include('partials/header') %>

<section class="page-hero">
  <div class="container">
    <h1 class="page-title">Ponte en <span class="text-gradient">Contacto</span></h1>
    <p class="page-subtitle">Cuéntame tu proyecto y te respondo en menos de 24 horas</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-grid">

      <!-- Info -->
      <div class="contact-info animate-on-scroll">
        <h3>¿Hablamos?</h3>
        <p>Estoy disponible para proyectos freelance, colaboraciones y consultas. Escríbeme y construyamos algo genial juntos.</p>

        <div class="contact-items">
          <div class="contact-item">
            <div class="contact-icon"><i class="fas fa-envelope"></i></div>
            <div>
              <strong>Correo</strong>
              <span>contacto@sistemasweb.com</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fab fa-whatsapp"></i></div>
            <div>
              <strong>WhatsApp</strong>
              <span>+51 925 196 141</span>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fas fa-map-marker-alt"></i></div>
            <div>
              <strong>Ubicación</strong>
              <span>Cusco, Perú</span>
            </div>
          </div>
        </div>

        <div class="social-links contact-social">
          <a href="#"><i class="fab fa-github"></i></a>
          <a href="#"><i class="fab fa-linkedin"></i></a>
          <a href="#"><i class="fab fa-whatsapp"></i></a>
        </div>
      </div>

      <!-- Formulario -->
      <div class="contact-form-wrap animate-on-scroll">
        <% if (success) { %>
          <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> ¡Mensaje enviado! Te respondo pronto.
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i> <%= error %>
          </div>
        <% } %>

        <form class="contact-form" action="/contacto" method="POST" id="contactForm">
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre *</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre completo" required />
            </div>
            <div class="form-group">
              <label for="email">Correo *</label>
              <input type="email" id="email" name="email" placeholder="tu@correo.com" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="+1 000 000 0000" />
            </div>
            <div class="form-group">
              <label for="asunto">Asunto</label>
              <input type="text" id="asunto" name="asunto" placeholder="Asunto del mensaje" />
            </div>
          </div>
          <div class="form-group">
            <label for="mensaje">Mensaje *</label>
            <textarea id="mensaje" name="mensaje" rows="5" placeholder="Cuéntame sobre tu proyecto..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-block">
            <i class="fas fa-paper-plane"></i> Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
