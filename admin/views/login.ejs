<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Admin Login' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/admin/assets/css/admin.css" />
</head>
<body>
<div class="login-page">
  <div class="login-box">
    <div class="login-logo"><i class="fas fa-shield-halved"></i></div>
    <h2>Panel Administrativo</h2>
    <p>Sistemas Web Studio</p>

    <% if (error) { %>
      <div class="login-alert"><i class="fas fa-circle-exclamation"></i> <%= error %></div>
    <% } %>

    <form class="login-form" action="/admin/login" method="POST">
      <div>
        <label for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" placeholder="admin@sistemasweb.com" required autofocus />
      </div>
      <div>
        <label for="password">Contraseña</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn-login"><i class="fas fa-right-to-bracket"></i> Ingresar</button>
    </form>

    <p style="margin-top:1.5rem; font-size:0.78rem; color:rgba(255,255,255,0.3);">
      <a href="/" style="color:rgba(255,255,255,0.4);">← Volver al sitio</a>
    </p>
  </div>
</div>
</body>
</html>
