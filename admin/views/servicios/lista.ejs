<%
  activeMenu = 'servicios';
%>
<%- include('../layout-header') %>

<div class="page-heading">
  <h2>Servicios</h2>
  <a href="/admin/servicios/nuevo" class="btn btn-primary"><i class="fas fa-plus"></i> Nuevo servicio</a>
</div>

<% if (success) { %><div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div><% } %>
<% if (error) { %><div class="alert alert-danger"><i class="fas fa-circle-exclamation"></i> <%= error %></div><% } %>

<div class="table-wrapper">
  <table>
    <thead>
      <tr><th>#</th><th>Ícono</th><th>Título</th><th>Precio</th><th>Estado</th><th>Acciones</th></tr>
    </thead>
    <tbody>
      <% if (servicios.length > 0) { %>
        <% servicios.forEach(s => { %>
        <tr>
          <td><%= s.id %></td>
          <td><i class="<%= s.icono %>" style="font-size:1.2rem; color:#0EA5E9;"></i></td>
          <td><strong><%= s.titulo %></strong></td>
          <td><%= s.precio ? '$' + parseFloat(s.precio).toLocaleString() : '—' %></td>
          <td><span style="font-size:0.75rem; font-weight:600; padding:3px 10px; border-radius:100px;
            background:<%= s.activo ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)' %>;
            color:<%= s.activo ? '#166534' : '#991B1B' %>;"><%= s.activo ? 'Activo' : 'Inactivo' %></span></td>
          <td>
            <a href="/admin/servicios/editar/<%= s.id %>" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
            <form action="/admin/servicios/eliminar/<%= s.id %>" method="POST" style="display:inline;"
                  onsubmit="return confirm('¿Eliminar?')">
              <button type="submit" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
            </form>
          </td>
        </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="6" style="text-align:center; padding:2rem; color:#9CA3AF;">Sin servicios aún.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../layout-footer') %>
