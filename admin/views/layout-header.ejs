<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Admin | Sistemas Web Studio' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <link rel="stylesheet" href="/admin/assets/css/admin.css" />
</head>
<body>
<div class="admin-layout">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon"><i class="fas fa-code"></i></div>
      <span>SWS Admin</span>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">
        <div class="nav-section-label">Principal</div>
        <a href="/admin" class="sidebar-link <%= (activeMenu==='dashboard') ? 'active' : '' %>">
          <i class="fas fa-gauge"></i> Dashboard
        </a>
      </div>
      <div class="nav-section">
        <div class="nav-section-label">Contenido</div>
        <a href="/admin/proyectos" class="sidebar-link <%= (activeMenu==='proyectos') ? 'active' : '' %>">
          <i class="fas fa-folder-open"></i> Proyectos
        </a>
        <a href="/admin/servicios" class="sidebar-link <%= (activeMenu==='servicios') ? 'active' : '' %>">
          <i class="fas fa-cogs"></i> Servicios
        </a>
        <a href="/admin/habilidades" class="sidebar-link <%= (activeMenu==='habilidades') ? 'active' : '' %>">
          <i class="fas fa-star"></i> Habilidades
        </a>
      </div>
      <div class="nav-section">
        <div class="nav-section-label">Comunicación</div>
        <a href="/admin/mensajes" class="sidebar-link <%= (activeMenu==='mensajes') ? 'active' : '' %>">
          <i class="fas fa-envelope"></i> Mensajes
          <% if (locals.mensajesNuevos > 0) { %>
            <span class="sidebar-badge"><%= mensajesNuevos %></span>
          <% } %>
        </a>
      </div>
      <div class="nav-section">
        <div class="nav-section-label">Sitio</div>
        <a href="/" target="_blank" class="sidebar-link">
          <i class="fas fa-globe"></i> Ver sitio
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user">
        <div class="user-avatar"><%= adminUser.nombre.charAt(0).toUpperCase() %></div>
        <div class="user-info">
          <strong><%= adminUser.nombre %></strong>
          <span><%= adminUser.rol %></span>
        </div>
      </div>
      <form action="/admin/logout" method="GET">
        <button type="submit" class="btn-logout"><i class="fas fa-right-from-bracket"></i> Cerrar sesión</button>
      </form>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="admin-main">
    <header class="admin-topbar">
      <span class="topbar-title"><%= title || 'Admin' %></span>
      <div class="topbar-actions">
        <a href="/admin/mensajes"><i class="fas fa-bell"></i></a>
        <a href="/" target="_blank"><i class="fas fa-external-link-alt"></i> Ver sitio</a>
      </div>
    </header>
    <div class="admin-content">
